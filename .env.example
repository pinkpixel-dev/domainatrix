# Environment variables for Domainatrix
PORT=8765
DB_FILE_NAME=./data/domainatrix.sqlite
CRON_SECRET=change-me
# Optional: Webhook URL for notifications (e.g., Discord, Slack)
NOTIFICATION_WEBHOOK_URL=
# Optional: SMTP settings for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=
# Optional: Google Cloud API key with Chrome UX Report API enabled
# https://developers.google.com/web/tools/chrome-user-experience-report/api/guides/getting-started
CRUX_API_KEY=
